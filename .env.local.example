# GoHighLevel Webhook URL
# Get this from GHL > Settings > Integrations > Webhooks > Create Webhook
# Set the trigger to "Form Submitted" or use a custom webhook trigger
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID/webhook-trigger/YOUR_TRIGGER_ID

# Optional: Set to your actual site URL once you have a domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000
